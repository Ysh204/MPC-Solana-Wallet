{
  "name": "college-cms",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "create-admin": "cd packages/db && bun run create-admin",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "postinstall": "node scripts/repair-bun-bins.mjs",
    "prisma": "node scripts/run-prisma.mjs",
    "prisma:studio": "node scripts/run-prisma.mjs studio --schema packages/db/prisma/schema.prisma",
    "prisma:studio:mpc": "node scripts/run-prisma.mjs studio --schema packages/mpc-db/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "jsonwebtoken": "^9.0.2",
    "pptxgenjs": "^4.0.1"
  }
}
